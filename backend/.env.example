DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vyroportify
SECRET_KEY=changeme-replace-with-32-plus-random-chars
ENVIRONMENT=development
DEBUG=true

# ── JWT ────────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ── Storage: choose "s3" or "r2" ─────────────────────────────────────────────
STORAGE_PROVIDER=s3

# AWS S3 (used when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=vyroportify-resumes

# Cloudflare R2 (used when STORAGE_PROVIDER=r2)
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vyroportify-resumes

# Presigned URL settings
PRESIGNED_URL_DEFAULT_HOURS=24
PRESIGNED_URL_MAX_HOURS=168
MAX_UPLOAD_SIZE_MB=5

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from https://dashboard.stripe.com/webhooks (after creating webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a product + recurring price at https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_PRODUCT_ID=prod_...
# Where Stripe redirects after checkout/portal
FRONTEND_URL=http://localhost:3007

# ── External services ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
