# ── Environment files (contain secrets — NEVER commit) ─────────────────────────
# These patterns are intentionally broad to catch common naming variants.
.env
.env.local
.env.production
.env.staging
.env.development
.env.*.local
.env.production.local
.env.staging.local
**/.env
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production
*.env.local
*.env.production

# ── Node / Next.js ──────────────────────────────────────────────────────────────
node_modules/
.next/
.nuxt/
.cache/
out/
dist/

# ── TypeScript ──────────────────────────────────────────────────────────────────
tsconfig.tsbuildinfo
*.tsbuildinfo

# ── Testing ─────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── IDE / Editor ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Uploads / temp files ────────────────────────────────────────────────────────
/tmp/portifyai_uploads/
uploads/
*.upload

# ── Secrets and key files ───────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ── Alembic ─────────────────────────────────────────────────────────────────────
# Don't ignore alembic/versions — those are migration files that must be committed.
# But ignore any local alembic.ini overrides.
alembic.ini.local

# ── Logs ────────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Claude Code ─────────────────────────────────────────────────────────────────
.claude/
*.claude/

# ── Playwright ──────────────────────────────────────────────────────────────────
playwright-report/
test-results/

# ── Vercel ──────────────────────────────────────────────────────────────────────
.vercel/

# ── Ruff ────────────────────────────────────────────────────────────────────────
.ruff_cache/
